    # async def update_log(
    #     self,
    #     db: AsyncSession,
    #     record_id: int,
    #     update_data: DmisLogsUpdateInternal,
    # ) -> Optional[DmisLogs]:
    #     return await self.update(db=db, id=record_id, object=update_data)


    async def update_log(
        self,
        db: AsyncSession,
        record_id: int,
        update_data: DmisLogsUpdateInternal,
    ) -> DmisLogs | None:

        stmt = select(DmisLogs).where(
            and_(
                DmisLogs.id == record_id,
                DmisLogs.is_deleted == False,
            )
        )

        result = await db.execute(stmt)

        obj = result.scalar_one_or_none()

        if not obj:
            return None

        for key, value in update_data.model_dump(
            exclude_unset=True
        ).items():
            setattr(obj, key, value)

        await db.flush()
        await db.refresh(obj)

        return obj
    

    
    # FILTER LOGS
    async def filter_logs(
        self,
        db: AsyncSession,
        endpoint: Optional[str] = None,
        method: Optional[str] = None,
        disability_code: Optional[str] = None,
        status: Optional[str] = None,
        is_received: Optional[bool] = None,
        created_by: Optional[int] = None,
    ) -> List[DmisLogs]:

        stmt = select(DmisLogs).where(DmisLogs.is_deleted == False)

        filters = []

        if endpoint:
            filters.append(DmisLogs.endpoint.ilike(f"%{endpoint}%"))

        if method:
            filters.append(DmisLogs.method == method)

        if disability_code:
            filters.append(DmisLogs.disability_code == disability_code)

        if status:
            filters.append(DmisLogs.status == status)

        if is_received is not None:
            filters.append(DmisLogs.is_received == is_received)

        if created_by:
            filters.append(DmisLogs.created_by == created_by)

        if filters:
            stmt = stmt.where(and_(*filters))

        stmt = stmt.order_by(DmisLogs.timestamp.desc())

        result = await db.execute(stmt)
        return result.scalars().all()
    
    # GET FAILED LOGS (useful helper)
    async def get_failed_logs(
        self, db: AsyncSession
    ) -> List[DmisLogs]:
        stmt = (
            select(DmisLogs)
            .where(
                DmisLogs.status != "200",
                DmisLogs.is_deleted == False,
            )
            .order_by(DmisLogs.timestamp.desc())
        )
        result = await db.execute(stmt)
        return result.scalars().all()


crud_dmis_logs = CRUDDmisLogs(DmisLogs)

