from typing import List, Optional

from fastcrud import FastCRUD
from sqlalchemy import select, func, and_
from sqlalchemy.ext.asyncio import AsyncSession

from ..models.incoming_dmis_logs import DmisLogs
from ..schemas.dmis_log import (
    DmisLogsCreateInternal,
    DmisLogsDelete,
    DmisLogsUpdate,
    DmisLogsUpdateInternal
)

class CRUDDmisLogs(
    FastCRUD[
        DmisLogs,
        DmisLogsCreateInternal,
        DmisLogsUpdate,
        DmisLogsUpdateInternal,
        DmisLogsDelete,
        None,
    ]
):
    """ CRUD operations for DMIS_Logs table with helper methods. """

    # GET BY DISABILITY CODE
    async def get_by_disability_code(
        self, db: AsyncSession, disability_code: str
    ) -> List[DmisLogs]:
        stmt = (
            select(DmisLogs)
            .where(
                DmisLogs.disability_code == disability_code,
                DmisLogs.is_deleted == False,
            )
            .order_by(DmisLogs.timestamp.desc())
        )
        result = await db.execute(stmt)
        return result.scalars().all()
    

    # GET ALL LOGS (RECENT FIRST)
    async def get_all_logs(
        self, db: AsyncSession, skip: int = 0, limit: int = 100
    ) -> List[DmisLogs]:
        stmt = (
            select(DmisLogs)
            .where(DmisLogs.is_deleted == False)
            .offset(skip)
            .limit(limit)
            .order_by(DmisLogs.timestamp.desc())
        )
        result = await db.execute(stmt)
        return result.scalars().all()
    

    # COUNT SUCCESS / FAILED
    async def count_by_status(
        self, db: AsyncSession, status: str
    ) -> int:
        stmt = select(func.count(DmisLogs.id)).where(
            DmisLogs.status == status,
            DmisLogs.is_deleted == False,
        )
        result = await db.execute(stmt)
        return result.scalar() or 0
    
    # CREATE LOG
    async def create_log(
        self,
        db: AsyncSession,
        log_data: DmisLogsCreateInternal
    ) -> DmisLogs:

        obj = DmisLogs(**log_data.model_dump())

        db.add(obj)
        await db.flush()      # get ID only
        await db.refresh(obj)

        return obj
    
